# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Nested crates are path dependencies, not workspace members, so cargo
# sometimes builds them standalone from within their own directory -
# their target/ and Cargo.lock are redundant with the ones above.
crates/*/target/
crates/*/Cargo.lock
