{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the editor windows and the detached chat window",
  "windows": ["main", "window-*", "chat-*"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "opener:default",
    "dialog:default",
    "updater:default",
    "process:default",
    "core:event:allow-emit-to",
    "core:event:allow-emit",
    "core:event:allow-listen"
  ]
}
